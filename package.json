{
  "name": "fable5-codex",
  "version": "0.3.0-alpha",
  "description": "OpenAI Codex plugin for evidence-first AI code review, audits, fact checks, codebase understanding, ECF run contracts, and subagent workflows.",
  "type": "module",
  "bin": {
    "fable5-codex": "bin/install.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate-package.ps1",
    "pack:dry-run": "npm pack --dry-run",
    "generate:demo": "python scripts/generate-demo-gif.py"
  },
  "files": [
    "assets",
    "benchmarks/README.md",
    "benchmarks/results/20260706T035611Z/*.md",
    "benchmarks/results/20260706T035611Z/summary.csv",
    "benchmarks/results/20260706T035611Z/summary.json",
    "benchmarks/results/latest-run.txt",
    "benchmarks/results/latest-summary.csv",
    "benchmarks/results/latest-summary.json",
    "bin",
    "docs",
    "examples",
    "plugins",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "codex",
    "openai-codex",
    "plugin",
    "codex-plugin",
    "skills",
    "agent-skills",
    "fable",
